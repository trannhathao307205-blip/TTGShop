<!DOCTYPE html><html lang="vi"><head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TTG Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        /* Tùy chỉnh đồng bộ màu sắc hệ thống */
        .btn-search-dark {
            background-color: #222;
            color: white;
            border: 1px solid #222;
        }
        .btn-search-dark:hover {
            background-color: #000;
            color: white;
        }
        .nav-cart-btn {
            color: white;
            transition: opacity 0.2s;
            font-size: 1.3rem;
        }
        .nav-cart-btn:hover {
            color: #f8f9fa;
            opacity: 0.9;
        }
        /* Style cho nút tài khoản tinh gọn ở Header */
        .account-zone .nav-link {
            padding: 0;
            color: #333 !important;
        }
    </style></head><body>
   
    <header class="py-3 bg-white border-bottom">
        <div class="container d-flex align-items-center justify-content-between">
            <a class="navbar-brand fw-bold fs-3 text-dark mb-0" href="/">TTG Shop</a>
            
            <div class="account-zone">
                <partial name="_LoginPartial" />
            </div>
        </div>
    </header>

    <nav class="navbar navbar-expand-lg py-2" style="background-color: #ff4500;">
        <div class="container d-flex align-items-center justify-content-between">
            
            <button class="navbar-toggler navbar-dark border-white me-2" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav align-items-lg-center">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle text-white fw-bold" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fa-solid fa-bars me-1"></i> Tất cả danh mục
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" asp-controller="Product" asp-action="Index">Tất cả sản phẩm</a></li>
                            <li><hr class="dropdown-divider"></li>
                            
                            @if (ViewBag.Categories != null)
                            {
                                if (ViewBag.Categories is Microsoft.AspNetCore.Mvc.Rendering.SelectList selectList)
                                {
                                    foreach (var item in selectList)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Product" asp-action="Index" asp-route-categoryId="@item.Value">
                                                @item.Text
                                            </a>
                                        </li>
                                    }
                                }
                                else if (ViewBag.Categories is IEnumerable<TTGShop.Models.Category> categories)
                                {
                                    foreach (var category in categories)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Product" asp-action="Index" asp-route-categoryId="@category.Id">
                                                @category.Name
                                            </a>
                                        </li>
                                    }
                                }
                            }
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white ms-lg-3" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                    </li>
                    
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white ms-lg-3 fw-bold border-start ps-3 border-white border-opacity-25" asp-controller="Categories" asp-action="Index">
                                <i class="fa-solid fa-gear me-1"></i> Quản lý danh mục
                            </a>
                        </li>
                    }
                </ul>

                <div class="flex-grow-1 mx-lg-4 my-2 my-lg-0">
                    <form asp-controller="Product" asp-action="Index" method="get" class="d-flex input-group input-group-sm">
                        <input type="text" 
                               name="searchString" 
                               value="@ViewData["CurrentFilter"]" 
                               class="form-control border-0" 
                               placeholder="Tìm tên sản phẩm gần đúng..." />
                        <button class="btn btn-search-dark px-3" type="submit">
                            <i class="fa fa-search"></i>
                        </button>
                    </form>
                </div>
            </div>

            <div class="ms-2">
                <a asp-controller="Cart" asp-action="Index" class="nav-cart-btn p-2" title="Giỏ hàng">
                    <i class="fa-solid fa-cart-shopping"></i>
                </a>
            </div>

        </div>
    </nav>

    <div class="container my-4" style="min-height: 60vh;">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-light pt-5 pb-3 mt-5 border-top">
        <div class="container">
            <div class="row text-secondary">
                <div class="col-md-3 mb-3">
                    <h6 class="text-dark fw-bold">Liên hệ</h6>
                    <p class="text-success fw-bold fs-5 mt-2">(+84) 0313-728-397</p>
                </div>
                <div class="col-md-3 mb-3">
                    <h6 class="text-dark fw-bold">Liên kết</h6>
                    <ul class="list-unstyled mt-2">
                        <li><a href="#" class="text-decoration-none text-secondary">About Besa</a></li>
                        <li><a href="#" class="text-decoration-none text-secondary">Sell on Besa</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-3">
                    <h6 class="text-dark fw-bold">Hỗ trợ</h6>
                    <ul class="list-unstyled mt-2">
                        <li><a href="#" class="text-decoration-none text-secondary">Help Center</a></li>
                        <li><a href="#" class="text-decoration-none text-secondary">How to Buy</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-3">
                    <h6 class="text-dark fw-bold">Mạng xã hội</h6>
                    <div class="d-flex gap-3 fs-4 mt-2">
                        <a href="#" class="text-primary"><i class="fa-brands fa-facebook"></i></a>
                        <a href="#" class="text-danger"><i class="fa-brands fa-youtube"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)</body></html>