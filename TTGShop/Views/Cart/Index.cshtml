@model IEnumerable<TTGShop.Models.CartItem>

<div class="container my-5">
    <h2 class="mb-4 fw-bold text-dark"><i class="fa-solid fa-cart-shopping text-orange me-2"></i>Giỏ hàng của bạn</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 shadow-sm rounded bg-white">
            <i class="fa-solid fa-box-open fs-1 text-muted mb-3"></i>
            <p class="fs-5 text-secondary">Giỏ hàng của bạn đang trống.</p>
            <a href="/" class="btn btn-primary px-4 py-2">Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8 mb-4">
                <div class="table-responsive shadow-sm rounded bg-white p-3">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Giá</th>
                                <th style="width: 120px;">Số lượng</th>
                                <th>Tổng tiền</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="@item.ImageUrl" alt="@item.ProductName" class="rounded me-3 border" style="width: 60px; height: 60px; object-fit: cover;" />
                                            <span class="fw-bold text-dark text-truncate" style="max-width: 250px;">@item.ProductName</span>
                                        </div>
                                    </td>
                                    <td class="text-danger fw-bold">@item.Price.ToString("N0") đ</td>
                                    <td>
                                        <div class="input-group input-group-sm">
                                            <input type="number" class="form-control text-center" value="@item.Quantity" min="1" readonly>
                                        </div>
                                    </td>
                                    <td class="text-danger fw-bold">@item.TotalPrice.ToString("N0") đ</td>
                                    <td>
                                        <a asp-controller="Cart" asp-action="RemoveFromCart" asp-route-id="@item.ProductId" class="btn btn-link text-muted p-0" title="Xóa">
                                            <i class="fa-solid fa-trash-can text-danger"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm p-4 bg-white rounded">
                    <h5 class="fw-bold mb-3 text-dark border-bottom pb-2">Tóm tắt đơn hàng</h5>
                    <div class="d-flex justify-content-between mb-3 fs-5">
                        <span>Tổng tiền:</span>
                        <span class="text-danger fw-bold fs-4">@Model.Sum(x => x.TotalPrice).ToString("N0") đ</span>
                    </div>
                    <p class="text-muted small mb-4">* Phí vận chuyển sẽ được nhân viên gọi xác nhận sau.</p>
                    <a asp-controller="Cart" asp-action="Checkout" class="btn w-100 py-2 fw-bold text-white" style="background-color: #ff4500;">
                        TIẾN HÀNH ĐẶT HÀNG
                    </a>
                </div>
            </div>
        </div>
    }
</div>