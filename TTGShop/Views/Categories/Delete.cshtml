@model TTGShop.Models.Category

@{
    ViewData["Title"] = "Xóa danh mục";
}

<div class="container mt-5">
    <div class="card shadow border-0 col-md-6 mx-auto p-4">
        <h3 class="text-danger mb-3 text-center">Xóa danh mục</h3>
        <p class="text-muted text-center mb-4">Bạn có chắc chắn muốn xóa danh mục này không? Hành động này không thể hoàn tác.</p>
        
        <div class="alert alert-warning border-0 shadow-sm mb-4">
            <div class="row align-items-center">
                <div class="col-sm-4 fw-bold text-secondary">
                    Tên danh mục:
                </div>
                <div class="col-sm-8 fs-5 fw-bold text-dark">
                    @Html.DisplayFor(model => model.Name)
                </div>
            </div>
        </div>
        
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger flex-grow-1">
                    <i class="fa-solid fa-trash-can me-1"></i> Xác nhận xóa
                </button>
                <a asp-action="Index" class="btn btn-light border flex-grow-1 text-secondary">
                    <i class="fa-solid fa-xmark me-1"></i> Hủy bỏ
                </a>
            </div>
        </form>
    </div>
</div>