@model IEnumerable<TTGShop.Models.Category>

@{
    ViewData["Title"] = "Danh sách danh mục";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="text-primary fw-bold mb-0">Quản lý danh mục</h3>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="fa-solid fa-plus me-1"></i> Thêm danh mục mới
        </a>
    </div>

    <div class="card shadow border-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-4" style="width: 10%;">STT</th>
                        <th style="width: 60%;">Tên danh mục</th>
                        <th class="text-center pe-4" style="width: 30%;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                                <i class="fa-solid fa-folder-open fs-3 mb-2 d-block"></i>
                                Chưa có danh mục nào được tạo.
                            </td>
                        </tr>
                    }
                    else
                    {
                        int stt = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">@stt</td>
                                <td class="fw-semibold text-dark fs-6">
                                    @Html.DisplayFor(modelItem => item.Name)
                                </td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Chỉnh sửa">
                                            <i class="fa-solid fa-pen-to-square"></i> Sửa
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info text-dark" title="Chi tiết">
                                            <i class="fa-solid fa-eye"></i> Xem
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Xóa">
                                            <i class="fa-solid fa-trash-can"></i> Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            stt++;
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>