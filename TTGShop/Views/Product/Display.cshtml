@model TTGShop.Models.Product
<div class="container mt-5">
    <div class="card shadow border-0 col-md-6 mx-auto p-4">
        <h3>@Model.Name</h3>
        <img src="@Model.ImageUrl" class="img-fluid rounded mb-3" />
        <p><strong>Giá:</strong> @Model.Price.ToString("N0") VNĐ</p>
        <p><strong>Mô tả:</strong> @Model.Description</p>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</div>